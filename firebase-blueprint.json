{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the platform (admin or client).",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Firebase Auth UID"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "firstName": {
          "type": "string"
        },
        "lastName": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": ["admin", "client", "commando", "partner"]
        },
        "companyId": {
          "type": "string",
          "description": "ID of the company this user belongs to"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["uid", "email", "firstName", "lastName", "role", "createdAt"]
    },
    "Mission": {
      "title": "Mission",
      "description": "A mission assigned to a commando or partner.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "assignedTo": { "type": "string", "description": "UID of the commando or partner" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["en_attente", "en_cours", "termine", "annule"] },
        "priority": { "type": "string", "enum": ["basse", "moyenne", "haute"] },
        "type": { "type": "string", "enum": ["audit", "implementation", "support", "formation"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "clientId", "title", "status", "type", "createdAt"]
    },
    "Payment": {
      "title": "Payment",
      "description": "A transaction record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "succeeded", "failed"] },
        "stripeId": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "amount", "currency", "status", "createdAt"]
    },
    "Log": {
      "title": "Log",
      "description": "A system or audit log.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "action", "timestamp"]
    },
    "Company": {
      "title": "Company",
      "description": "A client company registered on the platform.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "industry": {
          "type": "string"
        },
        "size": {
          "type": "string"
        },
        "pack": {
          "type": "string",
          "enum": ["starter", "pro", "enterprise"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["id", "name", "industry", "size", "pack", "createdAt"]
    },
    "Ticket": {
      "title": "Ticket",
      "description": "A support ticket created by a client.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "ID of the user who created the ticket" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["Nouveau", "En cours", "Résolu", "Fermé"] },
        "priority": { "type": "string", "enum": ["Basse", "Moyenne", "Haute", "Urgente"] },
        "clientName": { "type": "string" },
        "clientEmail": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "subject", "message", "status", "priority", "clientName", "clientEmail", "createdAt"]
    },
    "Task": {
      "title": "Task",
      "description": "A project or task in the Commando Pipeline.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "ID of the client associated with this task" },
        "title": { "type": "string" },
        "client": { "type": "string" },
        "columnId": { "type": "string" },
        "isOrder": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "client", "columnId", "createdAt"]
    },
    "Document": {
      "title": "Document",
      "description": "A file uploaded by a user or admin.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "ID of the user who owns the document" },
        "name": { "type": "string" },
        "url": { "type": "string" },
        "type": { "type": "string", "enum": ["livrable", "piece", "paiement", "contrat"] },
        "size": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "name", "url", "type", "size", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "An order placed by a client in the shop.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "ID of the client who placed the order" },
        "serviceName": { "type": "string" },
        "moduleId": { "type": "string" },
        "clientName": { "type": "string" },
        "status": { "type": "string", "enum": ["Nouveau", "Validé", "En cours", "Terminé"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "serviceName", "clientName", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/companies/{companyId}": {
      "schema": { "$ref": "#/entities/Company" },
      "description": "Stores company profiles."
    },
    "/tickets/{ticketId}": {
      "schema": { "$ref": "#/entities/Ticket" },
      "description": "Stores support tickets."
    },
    "/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Stores pipeline tasks/projects."
    },
    "/documents/{documentId}": {
      "schema": { "$ref": "#/entities/Document" },
      "description": "Stores document metadata."
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Stores client orders."
    },
    "/missions/{missionId}": {
      "schema": { "$ref": "#/entities/Mission" },
      "description": "Stores missions assigned to commandos or partners."
    },
    "/payments/{paymentId}": {
      "schema": { "$ref": "#/entities/Payment" },
      "description": "Stores payment records."
    },
    "/logs/{logId}": {
      "schema": { "$ref": "#/entities/Log" },
      "description": "Stores system logs."
    }
  }
}
