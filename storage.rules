rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Chats — fichiers envoyés dans la messagerie
    match /chats/{clientId}/{allPaths=**} {
      allow read: if request.auth != null &&
                  (request.auth.uid == clientId ||
                   firestore.get(/databases/ai-studio-42406826-d231-4e61-bda4-7369948f2694/documents/users/$(request.auth.uid)).data.role in ['admin', 'commando']);
      allow write: if request.auth != null &&
                   (request.auth.uid == clientId ||
                    firestore.get(/databases/ai-studio-42406826-d231-4e61-bda4-7369948f2694/documents/users/$(request.auth.uid)).data.role in ['admin', 'commando']);
    }

    // Documents opérations — fichiers chargés par le commando
    match /documents/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
                   firestore.get(/databases/ai-studio-42406826-d231-4e61-bda4-7369948f2694/documents/users/$(request.auth.uid)).data.role in ['admin', 'commando'];
    }

    // Tout le reste — accès restreint aux admins
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
                   firestore.get(/databases/ai-studio-42406826-d231-4e61-bda4-7369948f2694/documents/users/$(request.auth.uid)).data.role in ['admin', 'commando'];
    }
  }
}
